<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ==================================================================
		FACTION TECH LEVEL &amp; TRADER UPGRADES
		================================================================== -->

	<!-- Dark Elvish Kingdom: Medieval -> Industrial -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]/techLevel</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]/techLevel</xpath>
			<value>
				<techLevel>Industrial</techLevel>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]</xpath>
			<value>
				<techLevel>Industrial</techLevel>
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]/caravanTraderKinds</xpath>
		<value>
			<caravanTraderKinds>
				<li>Caravan_Outlander_BulkGoods</li>
				<li>Caravan_Outlander_CombatSupplier</li>
				<li MayRequire="Ludeon.RimWorld.Ideology">Caravan_Outlander_Slaver</li>
			</caravanTraderKinds>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]/visitorTraderKinds</xpath>
		<value>
			<visitorTraderKinds>
				<li>Visitor_Outlander_Standard</li>
			</visitorTraderKinds>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]/baseTraderKinds</xpath>
		<value>
			<baseTraderKinds>
				<li>Base_Outlander_Standard</li>
			</baseTraderKinds>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/FactionDef[defName="DarkElvishKingdom"]/raidLootMaker</xpath>
		<value>
			<raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
		</value>
	</Operation>

	<!-- ==================================================================
		LABEL CHANGES
		================================================================== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/label</xpath>
		<value>
			<label>marauder</label>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/label</xpath>
		<value>
			<label>blademaster</label>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/label</xpath>
		<value>
			<label>scout</label>
		</value>
	</Operation>

	<!-- ==================================================================
		APPAREL: BUDGETS &amp; RESTRICTIONS
		================================================================== -->

	<!-- Bump apparel budget for scout -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/apparelMoney</xpath>
		<value>
			<apparelMoney>500~800</apparelMoney>
		</value>
	</Operation>

	<!-- DarkElvish_Archer (scout): remove forced hood, disallow fancy headgear -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/apparelRequired/li[.="Apparel_HatHood"]</xpath>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/specificApparelRequirements/li[bodyPartGroup="UpperHead"]</xpath>
		<value>
			<li>
				<bodyPartGroup>UpperHead</bodyPartGroup>
				<alternateTagChoices>
					<li>
						<tag>IndustrialMilitaryBasic</tag>
						<chance>0.6</chance>
					</li>
					<li>
						<tag>IndustrialMilitaryAdvanced</tag>
						<chance>0.4</chance>
					</li>
				</alternateTagChoices>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/apparelDisallowTags</xpath>
		<match Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/apparelDisallowTags</xpath>
			<value>
				<li>Royal</li>
				<li>Circlet</li>
				<li>Robe</li>
				<li>BestowerHood</li>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]</xpath>
			<value>
				<apparelDisallowTags>
					<li>Royal</li>
					<li>Circlet</li>
					<li>Robe</li>
						<li>BestowerHood</li>
				</apparelDisallowTags>
			</value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/apparelTags</xpath>
		<value>
			<li>IndustrialMilitaryAdvanced</li>
		</value>
	</Operation>

	<!-- DarkElvish_Ranger (marauder): remove forced war veil, disallow fancy headgear -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/apparelRequired/li[.="Apparel_WarVeil"]</xpath>
	</Operation>
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/specificApparelRequirements/li[bodyPartGroup="FullHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/apparelDisallowTags</xpath>
		<match Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/apparelDisallowTags</xpath>
			<value>
				<li>Royal</li>
				<li>Circlet</li>
				<li>Robe</li>
				<li>BestowerHood</li>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]</xpath>
			<value>
				<apparelDisallowTags>
					<li>Royal</li>
					<li>Circlet</li>
					<li>Robe</li>
						<li>BestowerHood</li>
				</apparelDisallowTags>
			</value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/apparelTags</xpath>
		<value>
			<li>IndustrialMilitaryAdvanced</li>
		</value>
	</Operation>

	<!-- DarkElvish_Swordmaster: remove forced simple helmet, disallow fancy headgear -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/apparelRequired/li[.="Apparel_SimpleHelmet"]</xpath>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/specificApparelRequirements/li[bodyPartGroup="UpperHead"]</xpath>
		<value>
			<li>
				<bodyPartGroup>UpperHead</bodyPartGroup>
				<alternateTagChoices>
					<li>
						<tag>IndustrialMilitaryBasic</tag>
						<chance>0.6</chance>
					</li>
					<li>
						<tag>IndustrialMilitaryAdvanced</tag>
						<chance>0.4</chance>
					</li>
				</alternateTagChoices>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/specificApparelRequirements/li[bodyPartGroup="FullHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/apparelDisallowTags</xpath>
		<match Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/apparelDisallowTags</xpath>
			<value>
				<li>Royal</li>
				<li>Circlet</li>
				<li>Robe</li>
				<li>BestowerHood</li>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]</xpath>
			<value>
				<apparelDisallowTags>
					<li>Royal</li>
					<li>Circlet</li>
					<li>Robe</li>
						<li>BestowerHood</li>
				</apparelDisallowTags>
			</value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]/apparelTags</xpath>
		<value>
			<li>IndustrialMilitaryAdvanced</li>
		</value>
	</Operation>

	<!-- ==================================================================
		WEAPON TAG REPLACEMENTS &amp; LOADOUTS
		================================================================== -->

	<!-- Lord: elite leader, precision rifle + melee -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]/weaponTags</xpath>
		<value>
			<weaponTags>
				<li>CE_AI_SR</li>
				<li>MedievalMeleeAdvanced</li>
			</weaponTags>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]/weaponMoney</xpath>
		<value>
			<weaponMoney>
				<min>1800</min>
				<max>3500</max>
			</weaponMoney>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>4</min>
					<max>8</max>
				</primaryMagazineCount>
				<weightedAmmoCategories>
					<ArmorPiercing>0.4</ArmorPiercing>
					<HollowPoint>0.3</HollowPoint>
					<IncendiaryAP>0.3</IncendiaryAP>
				</weightedAmmoCategories>
				<shieldMoney>
					<min>800</min>
					<max>1600</max>
				</shieldMoney>
				<shieldTags>
					<li>OutlanderShield</li>
				</shieldTags>
				<shieldChance>0.6</shieldChance>
				<sidearms>
					<li>
						<sidearmMoney>
							<min>200</min>
							<max>400</max>
						</sidearmMoney>
						<weaponTags>
							<li>CE_Sidearm_Melee</li>
						</weaponTags>
					</li>
				</sidearms>
			</li>
		</value>
	</Operation>

	<!-- Ranger -> Marauder: melee + sidearm -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/weaponTags</xpath>
		<value>
			<weaponTags>
				<li>MedievalMeleeAdvanced</li>
			</weaponTags>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/weaponMoney</xpath>
		<value>
			<weaponMoney>
				<min>400</min>
				<max>800</max>
			</weaponMoney>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/skills</xpath>
		<value>
			<skills>
				<li>
					<skill>Melee</skill>
					<range>4~14</range>
				</li>
			</skills>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<shieldMoney>
					<min>200</min>
					<max>400</max>
				</shieldMoney>
				<shieldTags>
					<li>OutlanderShield</li>
				</shieldTags>
				<shieldChance>0.4</shieldChance>
				<forcedSidearm>
					<sidearmMoney>
						<min>80</min>
						<max>200</max>
					</sidearmMoney>
					<weaponTags>
						<li>CE_Sidearm</li>
					</weaponTags>
					<magazineCount>
						<min>2</min>
						<max>4</max>
					</magazineCount>
				</forcedSidearm>
			</li>
		</value>
	</Operation>

	<!-- Swordmaster: elite melee + sidearm -->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Swordmaster"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<shieldMoney>
					<min>500</min>
					<max>1000</max>
				</shieldMoney>
				<shieldTags>
					<li>OutlanderShield</li>
				</shieldTags>
				<shieldChance>0.6</shieldChance>
				<forcedSidearm>
					<sidearmMoney>
						<min>150</min>
						<max>300</max>
					</sidearmMoney>
					<weaponTags>
						<li>CE_Sidearm</li>
					</weaponTags>
					<magazineCount>
						<min>2</min>
						<max>4</max>
					</magazineCount>
				</forcedSidearm>
			</li>
		</value>
	</Operation>

	<!-- Archer -> Scout: SMG/carbine -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/weaponTags</xpath>
		<value>
			<weaponTags>
				<li>CE_SMG</li>
				<li>CE_AI_AR</li>
				<li>CE_Sidearm</li>
				<li>SimpleGun</li>
			</weaponTags>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/weaponMoney</xpath>
		<value>
			<weaponMoney>
				<min>250</min>
				<max>500</max>
			</weaponMoney>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]/skills</xpath>
		<value>
			<skills>
				<li>
					<skill>Shooting</skill>
					<range>6~12</range>
				</li>
				<li>
					<skill>Melee</skill>
					<range>4~10</range>
				</li>
			</skills>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Archer"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>3</min>
					<max>6</max>
				</primaryMagazineCount>
				<minAmmoCount>20</minAmmoCount>
				<sidearms>
					<li>
						<generateChance>0.5</generateChance>
						<sidearmMoney>
							<min>20</min>
							<max>100</max>
						</sidearmMoney>
						<weaponTags>
							<li>CE_Sidearm_Melee</li>
						</weaponTags>
					</li>
				</sidearms>
			</li>
		</value>
	</Operation>

	<!-- ==================================================================
		HEADGEAR REQUIREMENTS: military helmet via requiredTag
		================================================================== -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Lord"]/specificApparelRequirements</xpath>
		<value>
			<li>
				<bodyPartGroup>UpperHead</bodyPartGroup>
				<alternateTagChoices>
					<li>
						<tag>IndustrialMilitaryBasic</tag>
						<chance>0.6</chance>
					</li>
					<li>
						<tag>IndustrialMilitaryAdvanced</tag>
						<chance>0.4</chance>
					</li>
				</alternateTagChoices>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Ranger"]/specificApparelRequirements</xpath>
		<value>
			<li>
				<bodyPartGroup>UpperHead</bodyPartGroup>
				<alternateTagChoices>
					<li>
						<tag>IndustrialMilitaryBasic</tag>
						<chance>0.6</chance>
					</li>
					<li>
						<tag>IndustrialMilitaryAdvanced</tag>
						<chance>0.4</chance>
					</li>
				</alternateTagChoices>
			</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="DarkElvish_Spearmen"]/specificApparelRequirements/li[bodyPartGroup="UpperHead"]</xpath>
		<value>
			<li>
				<bodyPartGroup>UpperHead</bodyPartGroup>
				<alternateTagChoices>
					<li>
						<tag>IndustrialMilitaryBasic</tag>
						<chance>0.6</chance>
					</li>
					<li>
						<tag>IndustrialMilitaryAdvanced</tag>
						<chance>0.4</chance>
					</li>
				</alternateTagChoices>
			</li>
		</value>
	</Operation>

</Patch>
