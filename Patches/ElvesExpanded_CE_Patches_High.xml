	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="HighElvish_HeavyArcher"]/label</xpath>
		<value>
			<label>sharpshooter</label>
		</value>
	</Operation>

	<!-- ==================================================================
		APPAREL: RESTRICT DUELIST PLATE TO MELEE ELITES
		================================================================== -->

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="Apparel_DuelistPlateArmor"]/apparel/tags/li[.="MedievalMilitaryLight"]</xpath>
	</Operation>

	<!-- Bump apparel budgets for scouts and sharpshooters so they can afford composite helmets -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Archer"]/apparelMoney</xpath>
		<value>
			<apparelMoney>500~800</apparelMoney>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="HighElvish_HeavyArcher"]/apparelMoney</xpath>
		<value>
			<apparelMoney>500~1000</apparelMoney>
		</value>
	</Operation>

	<!-- Add broader military tags to composite helmet so it matches more pawn apparel tags -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_AdvancedHelmet"]/apparel/tags</xpath>
		<value>
			<li>IndustrialMilitary</li>
			<li>IndustrialMilitaryBasic</li>
		</value>
	</Operation>

	<!-- ==================================================================
		APPAREL: REMOVE FORCED MEDIEVAL HEADGEAR, DISALLOW FANCY TAGS
		================================================================== -->

	<!-- HighElvish_Spearmen: remove forced simple helmet, disallow fancy headgear -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]/apparelRequired/li[.="Apparel_SimpleHelmet"]</xpath>
	</Operation>
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]/specificApparelRequirements/li[bodyPartGroup="UpperHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]/specificApparelRequirements/li[bodyPartGroup="FullHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]/apparelDisallowTags</xpath>
		<match Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]/apparelDisallowTags</xpath>
			<value>
				<li>Royal</li>
				<li>Circlet</li>
				<li>Robe</li>
				<li>BestowerHood</li>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]</xpath>
			<value>
				<apparelDisallowTags>
					<li>Royal</li>
					<li>Circlet</li>
					<li>Robe</li>
						<li>BestowerHood</li>
				</apparelDisallowTags>
			</value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Spearmen"]/apparelTags</xpath>
		<value>
			<li>IndustrialMilitaryAdvanced</li>
		</value>
	</Operation>

