	<Operation Class="PatchOperationReplace">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Emperor"]/weaponMoney</xpath>
		<value>
			<weaponMoney>
				<min>1800</min>
				<max>3500</max>
			</weaponMoney>
		</value>
	</Operation>

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="HighElvish_Emperor"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<primaryMagazineCount>
					<min>4</min>
					<max>8</max>
				</primaryMagazineCount>
				<weightedAmmoCategories>
					<ArmorPiercing>0.4</ArmorPiercing>
					<HollowPoint>0.3</HollowPoint>
					<IncendiaryAP>0.3</IncendiaryAP>
				</weightedAmmoCategories>
