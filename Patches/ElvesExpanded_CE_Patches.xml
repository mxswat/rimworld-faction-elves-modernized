		FACTION TECH LEVEL & TRADER UPGRADES
		================================================================== -->

	<!-- High Elvish Kingdom: Medieval -> Industrial -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/FactionDef[defName="HighElvishKingdom"]/techLevel</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/FactionDef[defName="HighElvishKingdom"]/techLevel</xpath>
			<value>
				<techLevel>Industrial</techLevel>
			</value>
		</match>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/FactionDef[defName="HighElvishKingdom"]</xpath>
			<value>
				<techLevel>Industrial</techLevel>
			</value>
		</nomatch>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/FactionDef[defName="HighElvishKingdom"]/caravanTraderKinds</xpath>
		<value>
			<caravanTraderKinds>
				<li>Caravan_Outlander_BulkGoods</li>
				<li>Caravan_Outlander_CombatSupplier</li>
				<li>Caravan_Outlander_Exotic</li>
			</caravanTraderKinds>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/FactionDef[defName="HighElvishKingdom"]/visitorTraderKinds</xpath>
		<value>
			<visitorTraderKinds>
