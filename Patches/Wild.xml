<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ==================================================================
		WILD ELVISH — WEAPON TAG REPLACEMENTS &amp; LOADOUTS
		================================================================== -->

	<!-- Warrior: keep melee, CE loadout -->
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/PawnKindDef[defName="WildElvish_warrior"]</xpath>
		<value>
			<li Class="CombatExtended.LoadoutPropertiesExtension">
				<shieldMoney>
					<min>100</min>
					<max>150</max>
				</shieldMoney>
				<shieldTags>
					<li>TribalShield</li>
				</shieldTags>
				<shieldChance>0.6</shieldChance>
			</li>
		</value>
	</Operation>

